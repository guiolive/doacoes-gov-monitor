# =============================================================================
# Monitor de Doações GOV — variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env — ele está no .gitignore
# =============================================================================

# Token do bot Telegram (obtido com @BotFather)
TELEGRAM_TOKEN=seu_token_aqui

# ID do chat ou grupo (número positivo = chat pessoal, negativo = grupo)
TELEGRAM_CHAT_ID=-1003377430097

# ID do tópico no supergrupo com topics/forum (opcional)
# Deixe em branco para enviar para o canal principal do grupo
TELEGRAM_THREAD_ID=3

# Intervalo entre verificações em segundos (padrão: 300 = 5 minutos)
CHECK_INTERVAL_SEC=300

# Caminho do arquivo de estado (IDs já notificados)
# Em produção: /opt/doacoes-gov-monitor/ids_notificados.json
IDS_FILE=./ids_notificados.json
